# ── Mode ─────────────────────────────────────────────────────────────────────
# auto | mock | live
# mock = no credentials needed, great for testing
# live = requires all keys below
SIGNAL_MARKET_MODE=mock

# ── OnchainOS API (required for live mode) ────────────────────────────────────
# Get from: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Sandbox keys (quick start — remove before production)
# OKX_API_KEY=03f0b376-251c-4618-862e-ae92929e0416
# OKX_SECRET_KEY=652ECE8FF13210065B0851FFDA9191F7
# OKX_PASSPHRASE=onchainOS#666

# ── Agentic Wallet ────────────────────────────────────────────────────────────
# Private key of the agent's Agentic Wallet on X Layer
# NEVER commit this. Use environment secrets in CI/CD.
AGENT_PRIVATE_KEY=

# Deployed SignalRegistry contract address on X Layer
SIGNAL_REGISTRY_ADDRESS=

# ── x402 payments ─────────────────────────────────────────────────────────────
# Address that receives 0.001 USDT reputation query fees
X402_PAYMENT_ADDRESS=

# ── Moltbook ──────────────────────────────────────────────────────────────────
# For autonomous settlement posts to m/buildx
MOLTBOOK_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
XLAYER_RPC_URL=https://xlayerrpc.okx.com
